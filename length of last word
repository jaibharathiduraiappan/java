class Solution {
    public int lengthOfLastWord(String s) {
        // 1. Initialize a pointer at the end of the string
        int i = s.length() - 1;
        int length = 0;

        // 2. Skip all trailing spaces (like in Example 2: "moon  ")
        while (i >= 0 && s.charAt(i) == ' ') {
            i--;
        }

        // 3. Count characters until we hit another space or the start of the string
        while (i >= 0 && s.charAt(i) != ' ') {
            length++;
            i--;
        }

        return length;
    }
}
